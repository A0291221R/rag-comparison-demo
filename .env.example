# ─────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default model routing
LLM_CLASSIFICATION_MODEL=gpt-4o-mini       # cheap model for grading/routing
LLM_GENERATION_MODEL=gpt-4o                # expensive model for final answers
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_FT=embed-ft-v1             # fine-tuned adapter tag (optional)

# ─────────────────────────────────────────────
# LangSmith Observability
# ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=rag-comparison-demo

# ─────────────────────────────────────────────
# Vector Store — Qdrant
# ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                            # leave empty for local dev
QDRANT_COLLECTION=rag_demo
QDRANT_COLLECTION_FT=rag_demo_ft           # fine-tuned embeddings collection

# ─────────────────────────────────────────────
# Graph Database — Neo4j
# ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Optional: AWS Neptune
NEPTUNE_ENDPOINT=
NEPTUNE_PORT=8182
NEPTUNE_USE_IAM=false

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.95

# ─────────────────────────────────────────────
# PostgreSQL (LangGraph checkpointer)
# ─────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:password@localhost:5432/rag_demo

# ─────────────────────────────────────────────
# OpenTelemetry
# ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=rag-comparison-demo
OTEL_TRACES_EXPORTER=otlp

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_KEY=dev-secret-key
API_RATE_LIMIT_PER_MINUTE=60
API_PORT=8000
GRPC_PORT=50051

# ─────────────────────────────────────────────
# Pipeline Tuning
# ─────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
RELEVANCE_THRESHOLD=0.65
MAX_AGENT_ITERATIONS=3
RECURSION_LIMIT=25
TOKEN_BUDGET_PER_QUERY=8000
NODE_TIMEOUT_SECONDS=30

# ─────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────
FEATURE_GRAPHRAG_ENABLED=true
FEATURE_FINETUNED_EMBEDDINGS=false
FEATURE_WEB_SEARCH_FALLBACK=false
FEATURE_COMMUNITY_SUMMARIES=false
SHADOW_MODE_ENABLED=false
